#!/usr/bin/env bash
set -e  # Прерывает выполнение при первой же ошибке

# Загружаем Husky
#. "$(dirname -- "$0")/_/husky.sh"

echo "🛠️ Проверка стандартов проекта перед коммитом..."

# Проверка Prettier (форматирование)
echo "✨ Проверка форматирования с помощью Prettier..."
if ! npm run check-format; then
  echo "⚠️ Обнаружены проблемы с форматированием!"
  echo "🔧 Попытка автоматического исправления..."
  if npm run format; then
    echo "✅ Код успешно отформатирован!"
  else
    echo "❌ Ошибка форматирования. Исправьте вручную."
    exit 1
  fi
else
  echo "✅ Форматирование в порядке!"
fi

# Проверка ESLint (линтинг)
echo "🔍 Проверка кода с помощью ESLint..."
if ! npm run lint; then
  echo "❌ Ошибки линтинга найдены! Исправьте их перед коммитом."
  exit 1
fi

# Проверка сборки проекта
echo "🛠️ Проверка сборки..."
if ! npm run build; then
  echo "❌ Ошибка сборки! Проверьте код и исправьте ошибки."
  exit 1
fi

echo "✅ Все проверки пройдены. Коммит может быть выполнен."